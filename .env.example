# Token GitHub com escopos: repo, discussions:write (e contents se precisar)
GITHUB_TOKEN=ghp_seu_token_aqui

# Dono/org e nome do repositório
GITHUB_OWNER=livyson
GITHUB_REPO=DailyProject

# Branches
GIT_SOURCE_BRANCH=develop
GIT_TARGET_BRANCH=main

# Quantidade mínima de linhas geradas por execução
MIN_LINES=100

# Horários das 3 execuções diárias (formato HH:mm, fuso local)
SCHEDULE_TIMES=09:00,14:00,19:00

# Autor dos commits / comentários (persona)
AUTHOR_NAME=Livyson
AUTHOR_EMAIL=livyson@users.noreply.github.com
